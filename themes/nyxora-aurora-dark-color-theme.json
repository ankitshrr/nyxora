    "variable.defaultLibrary": { "foreground": "#498FE0" },
    "parameter": { "foreground": "#C0C7D6", "italic": true },
    "property": "#C0C7D6",
    "property.readonly": { "foreground": "#C9A045" },
    "property.declaration": { "foreground": "#C0C7D6" },
    "event": { "foreground": "#498FE0" },
    "string": "#C9A045",
    "number": "#498FE0",
    "regexp": { "foreground": "#3AA384" },
    "operator": "#498FE0",
    "keyword": { "foreground": "#E0854D", "italic": true },
    "keyword.control": { "foreground": "#E0854D", "italic": true },
