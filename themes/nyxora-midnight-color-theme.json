  "tokenColors": [
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "keyword.control",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#5C94FF",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Functions",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#5687CC"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.template",
        "punctuation.definition.string"
      ],
      "settings": {
        "foreground": "#65E39C"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "variable.other",
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#C5D4ED"
      }
    },
    {
      "name": "Numbers",
      "scope": [
        "constant.numeric"
      ],
      "settings": {
        "foreground": "#F47A83"
      }
    },
    {
      "name": "Types",
      "scope": [
        "entity.name.type",
        "support.type"
      ],
      "settings": {
        "foreground": "#FFB86C"
      }
    },
    {
      "name": "Classes",
      "scope": [
        "entity.name.type.class",
        "entity.name.class",
        "support.class"
      ],
      "settings": {
        "foreground": "#FFB86C",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Constants",
      "scope": [
        "constant.language",
        "constant.character",
        "constant.other"
      ],
      "settings": {
        "foreground": "#F47A83"
      }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#5687CC"
      }
    },
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#50648A",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Tags",
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#5687CC"
      }
    },
    {
      "name": "Attributes",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#FFB86C",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Properties",
      "scope": [
        "support.type.property-name",
        "meta.object-literal.key"
      ],
      "settings": {
        "foreground": "#C5D4ED"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation",
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.parameters",
        "punctuation.definition.array",
        "punctuation.definition.dictionary",
        "punctuation.definition.block",
        "meta.brace.round",
        "meta.brace.square",
        "meta.brace.curly"
      ],
      "settings": {
        "foreground": "#50648A"
      }
    }
  ],
  "semanticTokenColors": {
    "namespace": "#5C94FF",
    "namespace.declaration": { "foreground": "#5C94FF", "bold": true },
    "class": { "foreground": "#FFB86C", "bold": true },
    "class.declaration": { "foreground": "#FFB86C", "bold": true },
    "enum": { "foreground": "#FFB86C" },
    "enumMember": { "foreground": "#F47A83" },
    "interface": { "foreground": "#5C94FF", "italic": true },
    "struct": { "foreground": "#FFB86C" },
    "typeParameter": { "foreground": "#5C94FF", "italic": true },
    "type": { "foreground": "#FFB86C" },
    "function": "#5687CC",
    "function.declaration": { "foreground": "#5687CC" },
    "method": "#5687CC",
    "method.declaration": { "foreground": "#5687CC" },
    "macro": { "foreground": "#5C94FF", "italic": true },
    "decorator": { "foreground": "#FFB86C", "italic": true },
    "variable": "#C5D4ED",
    "variable.readonly": { "foreground": "#F47A83" },
    "variable.defaultLibrary": { "foreground": "#5C94FF" },
    "parameter": { "foreground": "#C5D4ED", "italic": true },
    "property": "#C5D4ED",
    "property.readonly": { "foreground": "#F47A83" },
    "property.declaration": { "foreground": "#C5D4ED" },
    "event": { "foreground": "#5C94FF" },
    "string": "#65E39C",
    "number": "#F47A83",
    "regexp": { "foreground": "#65E39C" },
    "operator": "#5687CC",
    "keyword": { "foreground": "#5C94FF", "italic": true },
    "keyword.control": { "foreground": "#5C94FF", "italic": true },
    "modifier": { "foreground": "#5C94FF", "italic": true },
    "comment": { "foreground": "#50648A", "italic": true },
    "selfKeyword": { "foreground": "#F47A83", "italic": true },
    "label": "#50648A"
  }
}
