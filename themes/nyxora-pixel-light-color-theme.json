  "tokenColors": [
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "keyword.control",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#7C5CC4",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Functions",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#1A8FA0"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.template",
        "punctuation.definition.string"
      ],
      "settings": {
        "foreground": "#1E9E78"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "variable.other",
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#1E2030"
      }
    },
    {
      "name": "Numbers",
      "scope": [
        "constant.numeric"
      ],
      "settings": {
        "foreground": "#C49B00"
      }
    },
    {
      "name": "Types",
      "scope": [
        "entity.name.type",
        "support.type"
      ],
      "settings": {
        "foreground": "#7C5CC4"
      }
    },
    {
      "name": "Classes",
      "scope": [
        "entity.name.type.class",
        "entity.name.class",
        "support.class"
      ],
      "settings": {
        "foreground": "#5B3FA8",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Constants",
      "scope": [
        "constant.language",
        "constant.character",
        "constant.other"
      ],
      "settings": {
        "foreground": "#9E6CC4"
      }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#8090A8"
      }
    },
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#B0BACC",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Tags",
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#7C5CC4"
      }
    },
    {
      "name": "Attributes",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#1A8FA0",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Properties",
      "scope": [
        "support.type.property-name",
        "meta.object-literal.key"
      ],
      "settings": {
        "foreground": "#1E2030"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation",
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.parameters",
        "punctuation.definition.array",
        "punctuation.definition.dictionary",
        "punctuation.definition.block",
        "meta.brace.round",
        "meta.brace.square",
        "meta.brace.curly"
      ],
      "settings": {
        "foreground": "#8090A8"
      }
    }
  ],
  "semanticTokenColors": {
    "namespace": "#1A8FA0",
    "namespace.declaration": { "foreground": "#1A8FA0", "bold": true },
    "class": { "foreground": "#5B3FA8", "bold": true },
    "class.declaration": { "foreground": "#5B3FA8", "bold": true },
    "enum": { "foreground": "#7C5CC4" },
    "enumMember": { "foreground": "#C49B00" },
    "interface": { "foreground": "#1A8FA0", "italic": true },
    "struct": { "foreground": "#7C5CC4" },
    "typeParameter": { "foreground": "#1A8FA0", "italic": true },
    "type": { "foreground": "#7C5CC4" },
    "function": "#1A8FA0",
    "function.declaration": { "foreground": "#1A8FA0" },
    "method": "#1A8FA0",
    "method.declaration": { "foreground": "#1A8FA0" },
    "macro": { "foreground": "#7C5CC4", "italic": true },
    "decorator": { "foreground": "#C49B00", "italic": true },
    "variable": "#1E2030",
    "variable.readonly": { "foreground": "#9E6CC4" },
    "variable.defaultLibrary": { "foreground": "#1A8FA0" },
    "parameter": { "foreground": "#1E2030", "italic": true },
    "property": "#1E2030",
    "property.readonly": { "foreground": "#9E6CC4" },
    "property.declaration": { "foreground": "#1E2030" },
    "event": { "foreground": "#1A8FA0" },
    "string": "#1E9E78",
    "number": "#C49B00",
    "regexp": { "foreground": "#1E9E78" },
    "operator": "#8090A8",
    "keyword": { "foreground": "#7C5CC4", "italic": true },
    "keyword.control": { "foreground": "#7C5CC4", "italic": true },
    "modifier": { "foreground": "#7C5CC4", "italic": true },
    "comment": { "foreground": "#B0BACC", "italic": true },
    "selfKeyword": { "foreground": "#D94F63", "italic": true },
    "label": "#8090A8"
  }
