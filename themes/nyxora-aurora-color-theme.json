  "tokenColors": [
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "keyword.control",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#D47033",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Functions",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#29856A"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.template",
        "punctuation.definition.string"
      ],
      "settings": {
        "foreground": "#A88536"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "variable.other",
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#454C59"
      }
    },
    {
      "name": "Numbers",
      "scope": [
        "constant.numeric"
      ],
      "settings": {
        "foreground": "#3478C4"
      }
    },
    {
      "name": "Types",
      "scope": [
        "entity.name.type",
        "support.type"
      ],
      "settings": {
        "foreground": "#5763B8"
      }
    },
    {
      "name": "Classes",
      "scope": [
        "entity.name.type.class",
        "entity.name.class",
        "support.class"
      ],
      "settings": {
        "foreground": "#5763B8",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Constants",
      "scope": [
        "constant.language",
        "constant.character",
        "constant.other"
      ],
      "settings": {
        "foreground": "#D47033"
      }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#3478C4"
      }
    },
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#8E98A6",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Tags",
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#29856A"
      }
    },
    {
      "name": "Attributes",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#A88536",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Properties",
      "scope": [
        "support.type.property-name",
        "meta.object-literal.key"
      ],
      "settings": {
        "foreground": "#454C59"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation",
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.parameters",
        "punctuation.definition.array",
        "punctuation.definition.dictionary",
        "punctuation.definition.block",
        "meta.brace.round",
        "meta.brace.square",
        "meta.brace.curly"
      ],
      "settings": {
        "foreground": "#8E98A6"
      }
    }
  ],
  "semanticTokenColors": {
    "namespace": "#3478C4",
    "namespace.declaration": { "foreground": "#3478C4", "bold": true },
    "class": { "foreground": "#5763B8", "bold": true },
    "class.declaration": { "foreground": "#5763B8", "bold": true },
    "enum": { "foreground": "#5763B8" },
    "enumMember": { "foreground": "#A88536" },
    "interface": { "foreground": "#3478C4", "italic": true },
    "struct": { "foreground": "#5763B8" },
    "typeParameter": { "foreground": "#3478C4", "italic": true },
    "type": { "foreground": "#5763B8" },
    "function": "#29856A",
    "function.declaration": { "foreground": "#29856A" },
    "method": "#29856A",
    "method.declaration": { "foreground": "#29856A" },
    "macro": { "foreground": "#3478C4", "italic": true },
    "decorator": { "foreground": "#A88536", "italic": true },
    "variable": "#454C59",
    "variable.readonly": { "foreground": "#A88536" },
    "variable.defaultLibrary": { "foreground": "#3478C4" },
    "parameter": { "foreground": "#454C59", "italic": true },
    "property": "#454C59",
    "property.readonly": { "foreground": "#A88536" },
    "property.declaration": { "foreground": "#454C59" },
    "event": { "foreground": "#3478C4" },
    "string": "#A88536",
    "number": "#3478C4",
    "regexp": { "foreground": "#29856A" },
    "operator": "#3478C4",
    "keyword": { "foreground": "#D47033", "italic": true },
    "keyword.control": { "foreground": "#D47033", "italic": true },
    "modifier": { "foreground": "#D47033", "italic": true },
    "comment": { "foreground": "#8E98A6", "italic": true },
    "selfKeyword": { "foreground": "#D47033", "italic": true },
    "label": "#8E98A6"
